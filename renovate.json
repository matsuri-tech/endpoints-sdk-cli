{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "addLabels": ["renovate"],
  "extends": [
    "config:recommended",
    ":configMigration",
    ":automergeMinor",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "reviewers": ["hrdtbs"],
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "matchDepTypes": ["action"],
      "matchPackageNames": ["actions/{/,}**", "matsuri-tech/{/,}**"],
      "pinDigests": false
    }
  ]
}
