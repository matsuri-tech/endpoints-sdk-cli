{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":configMigration",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "reviewers": ["hrdtbs"],
  "packageRules": [
    {
      "matchDepTypes": ["action"],
      "pinDigests": true,
      "matchPackageNames": ["!actions/{/,}**", "!matsuri-tech/{/,}**"]
    }
  ]
}
